{
  "info": {"name": "Gestion Empleados API",
           "_postman_id": "12345-empleados-collection",
           "description": "Colección para gestión de empleados",
           "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"},
 
    "item": [

    { "name": "Crear Empleado",
      "request": {
        "method": "POST",
        "header": [ {"key": "Content-Type",
                     "value": "application/json"}],
    
        "body": {"mode": "raw",
                 "raw": "{\n  \"cedula\": \"123456789\",\n  \"nombre\": \"Juan Perez\",\n  \"cargo\": \"ADMINISTRADOR\",\n  \"fecha\": \"2024-01-01\",\n  \"fechaIngreso\": \"2024-02-01\",\n  \"salario\": 2500000\n}"},

        "url": {"raw": "http://localhost:8080/api/empleados",
                "protocol": "http",
                "host": ["localhost"],
                "port": "8080",
                "path": ["api", "empleados"]}}},

    {"name": "Listar por Cargo",
     "request": {"method": "GET",
                "url": {"raw": "http://localhost:8080/api/empleados/cargo?cargo=ADMINISTRADOR",
                        "protocol": "http",
                        "host": ["localhost"],
                        "port": "8080",
                        "path": ["api", "empleados", "cargo"],
        "query": [{"key": "cargo",
                   "value": "ADMINISTRADOR"}]}}},

    {"name": "Listar por Rango de Fechas",
      "request": {"method": "GET",
                  "url": {"raw": "http://localhost:8080/api/empleados/fechas?inicio=2024-01-01&fin=2024-12-31",
                          "protocol": "http",
                          "host": ["localhost"],
                          "port": "8080",
                          "path": ["api", "empleados", "fechas"],
        "query": [{"key": "inicio",
                   "value": "2024-01-01"},
                  {"key": "fin",
                   "value": "2024-12-31"}]}}},

    {"name": "Obtener por ID",
     "request": {"method": "GET",
                 "url": {"raw": "http://localhost:8080/api/empleados/1",
                 "protocol": "http",
                 "host": ["localhost"],
                 "port": "8080",
                 "path": ["api", "empleados", "1"]}}}]
}
